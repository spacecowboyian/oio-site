---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Merch - OIO Racing"
  description="Official OIO Racing merchandise and gear."
>
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Merch</h1>
      <p class="text-xl text-zinc-400 mb-12">Official OIO Racing gear</p>

      <!-- Ecwid Store Embed Placeholder -->
      <div class="max-w-6xl mx-auto">
        <div class="bg-zinc-900 rounded-lg p-12 border border-zinc-800 text-center">
          <h2 class="text-2xl font-semibold mb-4">Store Coming Soon</h2>
          <p class="text-zinc-400 mb-6">
            We're setting up our merch store with Ecwid.
            Check back soon for t-shirts, stickers, and more OIO Racing gear.
          </p>
          <div id="ecwid-store">
            <!-- Ecwid store widget will be embedded here -->
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
