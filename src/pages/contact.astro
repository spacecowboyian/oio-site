---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact - OIO Racing"
  description="Get in touch with OIO Racing for sponsorship inquiries or general questions."
>
  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="max-w-2xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Get in Touch</h1>
        <p class="text-xl text-zinc-400 mb-12">
          Interested in sponsorship, collaboration, or just want to say hi? Reach out!
        </p>

        <form class="space-y-6">
          <div>
            <label for="name" class="block text-sm font-medium mb-2">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 rounded-lg focus:outline-none focus:ring-2 focus:ring-zinc-700"
              required
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium mb-2">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 rounded-lg focus:outline-none focus:ring-2 focus:ring-zinc-700"
              required
            />
          </div>

          <div>
            <label for="subject" class="block text-sm font-medium mb-2">Subject</label>
            <select
              id="subject"
              name="subject"
              class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 rounded-lg focus:outline-none focus:ring-2 focus:ring-zinc-700"
            >
              <option value="sponsorship">Sponsorship Inquiry</option>
              <option value="collaboration">Collaboration</option>
              <option value="general">General Question</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium mb-2">Message</label>
            <textarea
              id="message"
              name="message"
              rows="6"
              class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 rounded-lg focus:outline-none focus:ring-2 focus:ring-zinc-700"
              required
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full px-8 py-3 bg-white text-black font-semibold rounded-lg hover:bg-zinc-200 transition"
          >
            Send Message
          </button>
        </form>

        <div class="mt-12 pt-12 border-t border-zinc-800">
          <h2 class="text-2xl font-semibold mb-4">Connect With Us</h2>
          <div class="space-y-3 text-zinc-300">
            <p>
              <span class="font-medium">YouTube:</span>
              <a href="https://youtube.com/@oioracing" target="_blank" rel="noopener" class="text-zinc-400 hover:text-white ml-2">
                @oioracing
              </a>
            </p>
            <p>
              <span class="font-medium">Instagram:</span>
              <a href="https://instagram.com/oioracing" target="_blank" rel="noopener" class="text-zinc-400 hover:text-white ml-2">
                @oioracing
              </a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
