---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLatestVideo, getEmbedUrl } from '../lib/youtube';
import { getLatestPosts } from '../lib/instagram';

const latestVideo = await getLatestVideo();
const instagramPosts = await getLatestPosts(8);
---

<BaseLayout title="OIO Racing - Grassroots Racing Community">
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-b from-zinc-900 to-zinc-950 py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-5xl md:text-7xl font-bold mb-6 bg-gradient-to-r from-white to-zinc-400 bg-clip-text text-transparent">
          Outside Inside Outside
        </h1>
        <p class="text-xl md:text-2xl text-zinc-300 mb-8 leading-relaxed">
          Grassroots racing is not some polished pro fantasy. It's lived, accessible, chaotic, funny, and deeply human.
        </p>
        <div class="flex gap-4 justify-center flex-wrap">
          <a href="./videos" class="px-8 py-3 bg-white text-black font-semibold rounded-lg hover:bg-zinc-200 transition">
            Watch Videos
          </a>
          <a href="./sponsors" class="px-8 py-3 border border-zinc-600 text-white font-semibold rounded-lg hover:bg-zinc-800 transition">
            Become a Sponsor
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Video Section -->
  <section class="py-16 bg-zinc-950">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold mb-8 text-center">Latest from YouTube</h2>
      <div class="max-w-4xl mx-auto">
        {latestVideo ? (
          <div>
            <div class="aspect-video bg-zinc-900 rounded-lg overflow-hidden mb-4">
              <iframe
                src={getEmbedUrl(latestVideo.id)}
                title={latestVideo.title}
                class="w-full h-full"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
            <h3 class="text-xl font-semibold mb-2">{latestVideo.title}</h3>
            <p class="text-zinc-400">{latestVideo.description}</p>
          </div>
        ) : (
          <div class="aspect-video bg-zinc-900 rounded-lg flex items-center justify-center">
            <p class="text-zinc-500">No videos available. Configure YouTube API to fetch videos.</p>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-16 bg-zinc-900">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl font-bold mb-6">Building Cars, Drivers, and Stories</h2>
        <p class="text-lg text-zinc-300 leading-relaxed mb-4">
          OIO Racing shows the real side of grassroots motorsport: the builds, the learning curves,
          the track days, and the community that makes it all possible.
        </p>
        <p class="text-lg text-zinc-300 leading-relaxed">
          We're proving that you don't need a massive budget or pro sponsorship to race.
          You just need passion, persistence, and a willingness to learn.
        </p>
      </div>
    </div>
  </section>

  <!-- Instagram Feed Section -->
  <section class="py-16 bg-zinc-950">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold mb-8 text-center">Latest on Instagram</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 max-w-6xl mx-auto">
        {instagramPosts.map((post) => (
          <a
            href={post.permalink}
            target="_blank"
            rel="noopener"
            class="aspect-square bg-zinc-900 rounded-lg overflow-hidden hover:opacity-80 transition group relative"
          >
            {post.media_url && post.media_url !== '/placeholder-instagram.jpg' ? (
              <img src={post.media_url} alt={post.caption || 'Instagram post'} class="w-full h-full object-cover" />
            ) : (
              <div class="w-full h-full flex items-center justify-center">
                <p class="text-zinc-600 text-sm">Instagram post</p>
              </div>
            )}
            <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition flex items-center justify-center p-4">
              <p class="text-white text-sm text-center line-clamp-3">{post.caption}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="https://instagram.com/oioracing" target="_blank" rel="noopener" class="text-zinc-400 hover:text-white transition">
          Follow @oioracing on Instagram →
        </a>
      </div>
    </div>
  </section>

  <!-- Sponsor CTA Section -->
  <section class="py-20 bg-gradient-to-b from-zinc-900 to-zinc-950">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-4xl font-bold mb-6">Partner With Us</h2>
        <p class="text-xl text-zinc-300 mb-8">
          Looking to reach an engaged community of racing enthusiasts, builders, and drivers?
          Let's talk about sponsorship opportunities.
        </p>
        <a href="./sponsors" class="inline-block px-8 py-3 bg-white text-black font-semibold rounded-lg hover:bg-zinc-200 transition">
          View Sponsorship Info
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
