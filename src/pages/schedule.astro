---
import BaseLayout from '../layouts/BaseLayout.astro';
import events2026 from '../data/events.json';
import racingResults from '../data/racing-results.json';

// Get available years from racing results (rallycross and ksrallycross data)
const rallycrossYears = Object.keys(racingResults.rallycross)
  .filter(y => !isNaN(Number(y)))
  .map(Number);
const ksrallycrossYears = Object.keys(racingResults.ksrallycross || {})
  .filter(y => !isNaN(Number(y)))
  .map(Number);
const availableYears = Array.from(new Set([...rallycrossYears, ...ksrallycrossYears]))
  .sort((a, b) => b - a);

function getTotalTime(result: any): string {
  const time = result.total_time_corrected ?? result.total_time_official ?? result.total_time;
  if (typeof time === 'number') {
    return time.toFixed(3);
  }
  return time ?? 'N/A';
}

function getCombinedEventsForYear(year: number): any[] {
  const events: any[] = [];

  // Get KCR RallyCross events
  if (racingResults.rallycross[year]?.events) {
    racingResults.rallycross[year].events.forEach((event: any) => {
      events.push({
        ...event,
        series: 'KCR RallyCross',
        date: event.date,
        results: event.results || []
      });
    });
  }

  // Get KSRX events
  if (racingResults.ksrallycross[year]?.events) {
    racingResults.ksrallycross[year].events.forEach((event: any) => {
      events.push({
        ...event,
        series: 'KSRX',
        date: event.date,
        oio_drivers: event.oio_drivers || [],
        // Transform for compatibility with display logic
        results: (event.oio_drivers || []).map((driver: any) => ({
          driver: driver.name,
          car_number: driver.car_number,
          class: driver.class,
          class_full: driver.class,
          position: driver.position,
          total_time: driver.total_time,
          best_time: driver.fastest_run,
          car: driver.car,
          trophy_eligible: driver.first_in_class
        }))
      });
    });
  }

  // Sort by date
  return events.sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());
}

function groupAndSortByClass(results: any[]) {
  const grouped: { [key: string]: { class_full: string; drivers: any[]; fastestTime: number } } = {};

  results.forEach((result) => {
    const classKey = result.class || 'Unknown';
    if (!grouped[classKey]) {
      grouped[classKey] = {
        class_full: result.class_full || result.class || 'Unknown',
        drivers: [],
        fastestTime: Infinity
      };
    }
    grouped[classKey].drivers.push(result);

    // Track fastest time for sorting classes
    const time = result.total_time_corrected ?? result.total_time_official ?? result.total_time ?? result.best_time ?? result.best_run ?? Infinity;
    if (typeof time === 'number' && time < grouped[classKey].fastestTime) {
      grouped[classKey].fastestTime = time;
    }
  });

  // Sort drivers within each class by position
  Object.values(grouped).forEach((classGroup) => {
    classGroup.drivers.sort((a, b) => a.position - b.position);
  });

  // Convert to array and sort classes by fastest time
  const sorted = Object.entries(grouped)
    .map(([classCode, classGroup]) => ({
      classCode,
      ...classGroup
    }))
    .sort((a, b) => a.fastestTime - b.fastestTime);

  return sorted;
}

// Get 2026 data
const events2026List = events2026.events;
const pastEvents2026 = events2026List.filter((e: any) => e.oio_results && e.oio_results.length > 0);
const upcomingEvents2026 = events2026List.filter((e: any) => !e.oio_results || e.oio_results.length === 0);
---

<BaseLayout
  title="Schedule - OIO Racing"
  description="Race schedule and results for OIO Racing drivers and teams."
>
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Race Schedule & Results</h1>
      <p class="text-xl text-zinc-400 mb-8">OIO Racing events with driver results and achievements</p>

      {/* Year Selector */}
      <div class="max-w-4xl mx-auto mb-12">
        <div class="flex items-center gap-4">
          <label for="yearSelect" class="font-semibold text-zinc-200">Select Year:</label>
          <select id="yearSelect" class="px-4 py-2 rounded-lg bg-zinc-800 border border-zinc-700 text-white hover:border-zinc-600 cursor-pointer transition" onchange="window.location.href = `/${this.value}`">
            {availableYears.map((year) => (
              <option value={year} selected={year === 2026}>
                {year}
              </option>
            ))}
          </select>
        </div>
      </div>

      <div class="max-w-4xl mx-auto space-y-12">
        <div>
          <p class="text-zinc-400 mb-8">Select a year from the dropdown above to view season championships and race events for that year.</p>
          <a href="/2026" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-900/30 text-blue-300 hover:bg-blue-900/50 transition border border-blue-700/50">
            <span>View 2026 Season</span>
            <span>→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
