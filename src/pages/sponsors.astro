---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Sponsors - OIO Racing"
  description="Our sponsors and partners who make grassroots racing possible."
>
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Our Sponsors</h1>
      <p class="text-xl text-zinc-400 mb-12">Partners who believe in grassroots racing</p>

      <!-- Sponsor Grid -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 mb-16">
        {[...Array(8)].map(() => (
          <div class="bg-zinc-900 rounded-lg p-8 flex items-center justify-center aspect-square border border-zinc-800 hover:border-zinc-700 transition">
            <p class="text-zinc-600 text-sm">Sponsor Logo</p>
          </div>
        ))}
      </div>

      <!-- Become a Sponsor CTA -->
      <div class="max-w-3xl mx-auto text-center bg-gradient-to-br from-zinc-900 to-zinc-950 border border-zinc-800 rounded-xl p-12">
        <h2 class="text-3xl font-bold mb-4">Become a Sponsor</h2>
        <p class="text-lg text-zinc-300 mb-8">
          Reach an engaged community of racing enthusiasts, builders, and drivers.
          Partner with OIO Racing to grow your brand in the grassroots motorsport space.
        </p>
        <ul class="text-left max-w-xl mx-auto space-y-3 mb-8 text-zinc-300">
          <li class="flex items-start gap-2">
            <span class="text-green-500 mt-1">✓</span>
            <span>Logo placement on race cars and content</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-500 mt-1">✓</span>
            <span>Featured mentions in YouTube videos</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-500 mt-1">✓</span>
            <span>Social media exposure to our community</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-500 mt-1">✓</span>
            <span>Website presence and backlinks</span>
          </li>
        </ul>
        <a href={`${import.meta.env.BASE_URL}contact`} class="inline-block px-8 py-3 bg-white text-black font-semibold rounded-lg hover:bg-zinc-200 transition">
          Contact Us About Sponsorship
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
